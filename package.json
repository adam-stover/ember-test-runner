{
  "name": "ember-test-runner",
  "version": "1.1.0",
  "description": "Run Ember QUnit tests via the dev server",
  "license": "MIT",
  "author": "Adam Stover",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adam-stover/ember-test-runner.git"
  },
  "type": "module",
  "bin": {
    "ember-test-runner": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test test/lib.test.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "chrome-launcher": "^1.2.1",
    "chrome-remote-interface": "^0.34.0"
  }
}
